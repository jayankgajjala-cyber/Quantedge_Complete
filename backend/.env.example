# ═══════════════════════════════════════════════════════════════════
#  QUANTEDGE TRADING SYSTEM — COMPLETE PRODUCTION .env
#  Modules 1-8 + Multi-Source Data Manager
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
DEBUG=false
APP_VERSION=9.1.0

# ── Database (REQUIRED in production) ────────────────────────────
# Supabase (pooled, port 6543):
# DATABASE_URL=postgresql://postgres.PROJECTID:PASS@pooler.supabase.com:6543/postgres
# Neon: DATABASE_URL=postgresql://user:pass@host/quantedge?sslmode=require
DATABASE_URL=

# Local dev SQLite (used when DATABASE_URL is blank)
DB_PATH=data/db/quantedge.db

# ── Parquet Cache ─────────────────────────────────────────────────
# Production: PARQUET_CACHE_DIR=/tmp/parquet
PARQUET_CACHE_DIR=data/cache/parquet

# ── JWT (REQUIRED — generate ONCE, NEVER change) ─────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_GENERATED_ONCE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Auth ──────────────────────────────────────────────────────────
AUTH_USERNAME=Jayank8294
AUTH_PASSWORD=Jayanju@9498

# ── Resend OTP (REQUIRED) ─────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY
OTP_SENDER_EMAIL=noreply@yourdomain.com
OTP_RECIPIENT_EMAIL=jayankgajjala@gmail.com
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6

# ── Gmail SMTP Alerts (REQUIRED) ─────────────────────────────────
# Get App Password: myaccount.google.com/apppasswords
ALERT_EMAIL_FROM=your.gmail@gmail.com
ALERT_EMAIL_TO=jayankgajjala@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── HuggingFace FinBERT + BART (REQUIRED) ────────────────────────
# huggingface.co/settings/tokens
HF_API_KEY=hf_REPLACE_WITH_TOKEN
HF_INFERENCE_URL=https://api-inference.huggingface.co/models
FINBERT_MODEL=ProsusAI/finbert
SUMMARIZER_MODEL=facebook/bart-large-cnn

# ── NewsAPI (REQUIRED) ────────────────────────────────────────────
# newsapi.org — free: 100 req/day
NEWS_API_KEY=REPLACE_WITH_NEWSAPI_KEY
NEWS_CACHE_TTL_SECS=3600
NEWS_MAX_ARTICLES=10

# ── ScraperAPI — Proxy for Investing.com/Moneycontrol (RECOMMENDED)
# scraperapi.com — 1000 free credits on signup
# Without this, cloud-hosted scrapers are blocked by Cloudflare
SCRAPERAPI_KEY=

# ── CORS ──────────────────────────────────────────────────────────
# Local: *   Production: https://quantedge.vercel.app
CORS_ORIGINS=*
FRONTEND_BASE_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=3
LOCKOUT_SECONDS=30.0

# ── Macro Risk Thresholds ─────────────────────────────────────────
DXY_RISK_THRESHOLD=106.0
US10Y_RISK_THRESHOLD=5.0
BRENT_RISK_THRESHOLD=95.0

# ── Sentiment Thresholds ─────────────────────────────────────────
SENTIMENT_NEGATIVE_THRESHOLD=-0.6
SENTIMENT_POSITIVE_THRESHOLD=0.6
SENTIMENT_CONFLICT_THRESHOLD=1.0

# ── Data Quality ──────────────────────────────────────────────────
MIN_YEARS_SUFFICIENT=10
MIN_YEARS_CONFIDENCE=2

# ── Budget & Trading ──────────────────────────────────────────────
MONTHLY_BUDGET_INR=15000
MAX_SINGLE_TRADE_PCT=0.40
MIN_SINGLE_TRADE_PCT=0.10
HIGH_CONFIDENCE_THRESHOLD=75.0
COMMISSION_PCT=0.001
ALERT_CONFIDENCE_THRESHOLD=85.0
MAX_ALERTS_PER_DAY=3
HEARTBEAT_INTERVAL_SECS=300

# ── Scheduler ─────────────────────────────────────────────────────
# NOTE: APScheduler timezone set to Asia/Kolkata in main.py
WEEKLY_BACKTEST_DAY=5
WEEKLY_BACKTEST_HOUR_UTC=1
WEEKLY_REPORT_DAY=5
WEEKLY_REPORT_HOUR_UTC=18

# ── TradingView Confidence Factors ────────────────────────────────
TV_CONFIDENCE_PENALTY=5.0
TV_CONFIRM_BONUS=12.0
MC_CONFIRM_BONUS=8.0

# ── Backtesting ───────────────────────────────────────────────────
INITIAL_CAPITAL=100000.0
RISK_FREE_RATE=0.065
TRADING_DAYS_PER_YEAR=252
