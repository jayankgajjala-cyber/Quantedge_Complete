# ═══════════════════════════════════════
#  Quantedge — .gitignore
# ═══════════════════════════════════════

# ── CRITICAL: Never commit secrets ────
.env
.env.local
.env.production
.env.*.local
*.env

# ── Python ────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
pip-wheel-metadata/
.venv/
venv/
env/
ENV/

# ── Database (local SQLite only) ──────
data/db/*.db
data/db/*.db-shm
data/db/*.db-wal

# ── Parquet cache (rebuilt from API) ──
data/cache/
*.parquet
/tmp/parquet/

# ── Logs ──────────────────────────────
logs/
*.log

# ── Node.js (frontend) ────────────────
node_modules/
.next/
.vercel/
out/
frontend/.env.local

# ── Testing ───────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────
*.tar.gz
